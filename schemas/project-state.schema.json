{
  "$defs": {
    "Authority": {
      "additionalProperties": false,
      "properties": {
        "actor": {
          "minLength": 1,
          "title": "Actor",
          "type": "string"
        },
        "level": {
          "$ref": "#/$defs/AuthorityLevel"
        },
        "source_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Ref"
        }
      },
      "required": [
        "actor",
        "level"
      ],
      "title": "Authority",
      "type": "object"
    },
    "AuthorityLevel": {
      "enum": [
        "explicit_user_approval",
        "user_instruction",
        "canonical_artifact",
        "verified_evidence",
        "accepted_decision",
        "assistant_proposal",
        "assistant_inference"
      ],
      "title": "AuthorityLevel",
      "type": "string"
    },
    "PrivacyClass": {
      "enum": [
        "public",
        "project_internal",
        "sensitive",
        "secret"
      ],
      "title": "PrivacyClass",
      "type": "string"
    },
    "StateConflict": {
      "additionalProperties": false,
      "properties": {
        "conflict_id": {
          "title": "Conflict Id",
          "type": "string"
        },
        "section": {
          "$ref": "#/$defs/StateSection"
        },
        "key": {
          "title": "Key",
          "type": "string"
        },
        "existing_event": {
          "title": "Existing Event",
          "type": "string"
        },
        "incoming_event": {
          "title": "Incoming Event",
          "type": "string"
        },
        "existing_summary": {
          "title": "Existing Summary",
          "type": "string"
        },
        "incoming_summary": {
          "title": "Incoming Summary",
          "type": "string"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "status": {
          "default": "unresolved",
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "conflict_id",
        "section",
        "key",
        "existing_event",
        "incoming_event",
        "existing_summary",
        "incoming_summary",
        "reason"
      ],
      "title": "StateConflict",
      "type": "object"
    },
    "StateItem": {
      "additionalProperties": false,
      "properties": {
        "key": {
          "title": "Key",
          "type": "string"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        },
        "details": {
          "additionalProperties": true,
          "title": "Details",
          "type": "object"
        },
        "rationale": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rationale"
        },
        "status": {
          "default": "active",
          "title": "Status",
          "type": "string"
        },
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "source_event": {
          "title": "Source Event",
          "type": "string"
        },
        "authority": {
          "$ref": "#/$defs/Authority"
        },
        "privacy_class": {
          "$ref": "#/$defs/PrivacyClass"
        },
        "updated_at": {
          "format": "date-time",
          "title": "Updated At",
          "type": "string"
        }
      },
      "required": [
        "key",
        "summary",
        "confidence",
        "source_event",
        "authority",
        "privacy_class",
        "updated_at"
      ],
      "title": "StateItem",
      "type": "object"
    },
    "StateSection": {
      "enum": [
        "mission",
        "current_phase",
        "scope_included",
        "scope_excluded",
        "authority_sources",
        "active_decisions",
        "constraints",
        "verified_facts",
        "assumptions",
        "rejected_approaches",
        "open_questions",
        "blockers",
        "risks",
        "completed_outcomes",
        "next_authorized_action",
        "continuity_warnings"
      ],
      "title": "StateSection",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "project_id": {
      "title": "Project Id",
      "type": "string"
    },
    "state_version": {
      "minimum": 0,
      "title": "State Version",
      "type": "integer"
    },
    "derived_through_sequence": {
      "minimum": 0,
      "title": "Derived Through Sequence",
      "type": "integer"
    },
    "derived_through_event": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Derived Through Event"
    },
    "generated_at": {
      "format": "date-time",
      "title": "Generated At",
      "type": "string"
    },
    "state_hash": {
      "default": "",
      "title": "State Hash",
      "type": "string"
    },
    "mission": {
      "anyOf": [
        {
          "$ref": "#/$defs/StateItem"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "current_phase": {
      "anyOf": [
        {
          "$ref": "#/$defs/StateItem"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "next_authorized_action": {
      "anyOf": [
        {
          "$ref": "#/$defs/StateItem"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "scope_included": {
      "additionalProperties": {
        "$ref": "#/$defs/StateItem"
      },
      "title": "Scope Included",
      "type": "object"
    },
    "scope_excluded": {
      "additionalProperties": {
        "$ref": "#/$defs/StateItem"
      },
      "title": "Scope Excluded",
      "type": "object"
    },
    "authority_sources": {
      "additionalProperties": {
        "$ref": "#/$defs/StateItem"
      },
      "title": "Authority Sources",
      "type": "object"
    },
    "active_decisions": {
      "additionalProperties": {
        "$ref": "#/$defs/StateItem"
      },
      "title": "Active Decisions",
      "type": "object"
    },
    "constraints": {
      "additionalProperties": {
        "$ref": "#/$defs/StateItem"
      },
      "title": "Constraints",
      "type": "object"
    },
    "verified_facts": {
      "additionalProperties": {
        "$ref": "#/$defs/StateItem"
      },
      "title": "Verified Facts",
      "type": "object"
    },
    "assumptions": {
      "additionalProperties": {
        "$ref": "#/$defs/StateItem"
      },
      "title": "Assumptions",
      "type": "object"
    },
    "rejected_approaches": {
      "additionalProperties": {
        "$ref": "#/$defs/StateItem"
      },
      "title": "Rejected Approaches",
      "type": "object"
    },
    "open_questions": {
      "additionalProperties": {
        "$ref": "#/$defs/StateItem"
      },
      "title": "Open Questions",
      "type": "object"
    },
    "blockers": {
      "additionalProperties": {
        "$ref": "#/$defs/StateItem"
      },
      "title": "Blockers",
      "type": "object"
    },
    "risks": {
      "additionalProperties": {
        "$ref": "#/$defs/StateItem"
      },
      "title": "Risks",
      "type": "object"
    },
    "completed_outcomes": {
      "additionalProperties": {
        "$ref": "#/$defs/StateItem"
      },
      "title": "Completed Outcomes",
      "type": "object"
    },
    "continuity_warnings": {
      "additionalProperties": {
        "$ref": "#/$defs/StateItem"
      },
      "title": "Continuity Warnings",
      "type": "object"
    },
    "conflicts": {
      "additionalProperties": {
        "$ref": "#/$defs/StateConflict"
      },
      "title": "Conflicts",
      "type": "object"
    }
  },
  "required": [
    "project_id",
    "state_version",
    "derived_through_sequence",
    "generated_at"
  ],
  "title": "ProjectState",
  "type": "object"
}
